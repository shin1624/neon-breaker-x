{
  "name": "neon-breaker-x",
  "version": "1.0.0",
  "description": "THE ULTIMATE BLOCK BREAKER - Neon Cyberpunk style",
  "type": "module",
  "scripts": {
    "serve": "python3 -m http.server 8080",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
