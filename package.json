    "test:e2e:ui": "playwright test --ui",
    "test:all": "vitest run && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "@vitest/coverage-v8": "^1.6.0",
    "vitest": "^1.6.0",
    "jsdom": "^24.0.0"
  }
}
